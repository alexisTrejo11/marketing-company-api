# =============================================================================
# Marketing Company API — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in values for your environment:
#   cp .env.example .env
#
# Loaded automatically via spring-dotenv (local) and docker compose `--env-file .env`.
# Docker files live in `docker/` — see docker/README.md.
# Never commit `.env` — it is listed in `.gitignore`.
# =============================================================================

# -----------------------------------------------------------------------------
# Spring
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# PostgreSQL (single source of truth — app + Docker postgres service)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketing_company_db
DB_USERNAME=postgres
DB_PASSWORD=change-me

# Host port published by Docker Compose only (compose.full.yml)
DB_HOST_PORT=5431

# -----------------------------------------------------------------------------
# Redis (single source of truth — connection URL)
# -----------------------------------------------------------------------------
# Production / Upstash (TLS):
#   REDIS_URL=rediss://default:YOUR_PASSWORD@your-endpoint.upstash.io:6379
# compose.full.yml overrides to redis://redis:6379 inside the app container.
# compose.deploy.yml and ./gradlew bootRun use this URL as-is (Upstash / cloud).
REDIS_URL=rediss://default:YOUR_PASSWORD@your-endpoint.upstash.io:6379

# Namespace all Redis keys for this project (use a unique value per app on shared Upstash/local Redis)
REDIS_KEY_PREFIX=marketing-company-api:

# Host port published by Docker Compose only — compose.full.yml
REDIS_HOST_PORT=6378

# -----------------------------------------------------------------------------
# JWT (required — use strong random strings, min. 32 characters each)
# Generate examples:
#   openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=30
AUTH_MAX_SESSIONS_PER_USER=5

# -----------------------------------------------------------------------------
# CORS (comma-separated frontend origins)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# -----------------------------------------------------------------------------
# Docker Compose — host port mappings (see docker/README.md)
# Local full:  docker compose -f docker/compose.full.yml --env-file .env up --build
# Deploy app:  docker compose -f docker/compose.deploy.yml --env-file .env up --build -d
# -----------------------------------------------------------------------------
APP_HOST_PORT=8081

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
EMAIL_FROM=no-reply@example.com
EMAIL_ENABLED=false

# -----------------------------------------------------------------------------
# Notifications (optional)
# -----------------------------------------------------------------------------
WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
SPRING_APPLICATION_NAME=MarketingCRMCompany

# -----------------------------------------------------------------------------
# Messaging (optional — production / AWS)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=
